---
import FilmPoster from "../components/FilmPoster.astro";
import Footer from "../components/Footer.astro";
import activity from "../data/activity.json";
import people from "../data/people.json";
import Base from "../layouts/Base.astro";
import type { ActivityData } from "../functions/activity";
import { formatWatchedDate, stars } from "../functions/activity";
import { hueFor, initials, loadAvatarSet } from "../functions/avatars";
import { profileUrl, type Person } from "../functions/people";
import { validatePeople } from "../functions/validate";

export function getStaticPaths() {
	return (people as Person[]).map((person) => ({
		params: { username: person.username },
		props: { person },
	}));
}

validatePeople(people);

interface Props {
	person: Person;
}

const { person: p } = Astro.props;
const hasAvatar = loadAvatarSet().has(p.username);
const { recent = [], favorites = [] } =
	(activity as ActivityData).people[p.username] ?? {};

const title = `${p.name} on Letterboxd (@${p.username}) — Fameboxd`;
const filmList = (films: { title: string }[]) =>
	films.map((f) => f.title).join(", ");
const description = [
	`${p.name}'s verified Letterboxd account.`,
	recent.length > 0 && `Recently watched: ${filmList(recent)}.`,
	favorites.length > 0 && `Favorite films: ${filmList(favorites)}.`,
	p.description,
]
	.filter(Boolean)
	.join(" ");
---

<Base title={title} description={description}>
	<main class="wrap py-8">
		<a
			class="text-[0.9rem] font-semibold text-text-dim no-underline hover:text-text"
			href="/">&larr; All people</a
		>

		<header class="mt-6 flex flex-wrap items-center gap-4">
			{
				hasAvatar ? (
					<img
						class="h-[72px] w-[72px] shrink-0 rounded-full border border-border bg-bg object-cover"
						src={`/avatars/${p.username}.webp`}
						width="72"
						height="72"
						alt=""
					/>
				) : (
					<span
						class="flex h-[72px] w-[72px] shrink-0 items-center justify-center rounded-full border text-[1.4rem] font-bold tracking-[0.02em] text-[hsl(var(--hue)_55%_80%)] bg-[hsl(var(--hue)_32%_24%)] border-[hsl(var(--hue)_28%_34%)]"
						aria-hidden="true"
						style={`--hue:${hueFor(p.name)}`}
					>
						{initials(p.name)}
					</span>
				)
			}
			<div class="min-w-0">
				<h1
					class="m-0 text-[clamp(1.5rem,4vw,2.1rem)] font-extrabold leading-[1.1] tracking-[-0.02em]"
				>
					{p.name}
				</h1>
				<ul
					class="mt-1.5 flex flex-wrap items-center gap-[0.35rem] p-0"
					aria-label="Tags"
				>
					{
						p.tags.map((t) => (
							<li class="list-none rounded-full border border-blue/30 bg-blue/[0.14] px-2 py-[0.1rem] text-[0.68rem] font-bold uppercase tracking-[0.04em] text-blue">
								{t}
							</li>
						))
					}
				</ul>
			</div>
			<a
				class="ml-auto rounded-full border border-border bg-bg-raised px-4 py-1.5 text-[0.85rem] font-semibold text-orange no-underline transition-colors duration-[120ms] hover:bg-bg-raised-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue motion-reduce:transition-none"
				href={profileUrl(p.username)}
				target="_blank"
				rel="noopener"
			>
				@{p.username} on Letterboxd &nearr;
			</a>
		</header>

		<p class="mt-4 max-w-[68ch] text-[0.95rem] leading-[1.6] text-text-dim">
			{p.description}
		</p>

		<section class="mt-8" aria-labelledby="recent-heading">
			<h2
				id="recent-heading"
				class="m-0 text-[0.8rem] font-bold uppercase tracking-[0.08em] text-text-faint"
			>
				Recently watched
			</h2>
			{
				recent.length > 0 ? (
					<ul class="mt-3 grid max-w-[640px] grid-cols-4 gap-2 p-0 sm:gap-3">
						{recent.map((f) => (
							<FilmPoster
								title={f.year ? `${f.title} (${f.year})` : f.title}
								poster={f.poster}
								url={f.url}
							>
								<span class="mt-1 flex flex-wrap items-baseline justify-between gap-x-2">
									{f.rating != null && (
										<span
											class="text-[0.72rem] tracking-[0.05em] text-green sm:text-[0.8rem]"
											aria-label={`Rated ${f.rating} out of 5`}
										>
											{stars(f.rating)}
										</span>
									)}
									{f.watchedDate && (
										<span class="text-[0.68rem] text-text-faint sm:text-[0.72rem]">
											{formatWatchedDate(f.watchedDate)}
										</span>
									)}
								</span>
							</FilmPoster>
						))}
					</ul>
				) : (
					<p class="mt-3 text-[0.9rem] text-text-faint">
						No films logged recently.
					</p>
				)
			}
		</section>

		<section class="mt-8" aria-labelledby="favorites-heading">
			<h2
				id="favorites-heading"
				class="m-0 text-[0.8rem] font-bold uppercase tracking-[0.08em] text-text-faint"
			>
				Favorite films
			</h2>
			{
				favorites.length > 0 ? (
					<ul class="mt-3 grid max-w-[640px] grid-cols-4 gap-2 p-0 sm:gap-3">
						{favorites.map((f) => (
							<FilmPoster title={f.title} poster={f.poster} url={f.url} />
						))}
					</ul>
				) : (
					<p class="mt-3 text-[0.9rem] text-text-faint">
						No favorites picked on their profile.
					</p>
				)
			}
		</section>
	</main>

	<Footer />
</Base>
