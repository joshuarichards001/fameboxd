---
import DirectoryPage from "../components/DirectoryPage.astro";
import people from "../data/people.json";
import { tagsByFrequency, type Person } from "../functions/people";
import { tagSlug } from "../functions/tags";

// One static page per tag in use (/directors/, /actors/, …), for SEO:
// each gets a targeted title, description, and h1, pre-filtered server-side.
export function getStaticPaths() {
	return tagsByFrequency(people as Person[]).map((tag) => ({
		params: { tag: tagSlug(tag) },
		props: { tag },
	}));
}

interface Props {
	tag: string;
}

const { tag } = Astro.props;
---

<DirectoryPage activeTag={tag} />
