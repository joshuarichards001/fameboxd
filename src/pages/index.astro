---
import Directory from "../components/Directory.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SearchControls from "../components/SearchControls.astro";
import activity from "../data/activity.json";
import people from "../data/people.json";
import type { ActivityData } from "../functions/activity";
import { loadAvatarSet } from "../functions/avatars";
import { sortPeople, tagsByFrequency } from "../functions/people";
import { validatePeople } from "../functions/validate";
import Base from "../layouts/Base.astro";

validatePeople(people);

const sorted = sortPeople(people);
const allTags = tagsByFrequency(sorted);
const total = sorted.length;
const avatarSet = loadAvatarSet();

const title = "Fameboxd";
const description = `A searchable directory of ${total} famous actors, directors, musicians, youtubers, and creators with verified Letterboxd accounts.`;
---

<Base title={title} description={description}>
    <Header />

    <main class="wrap">
        <SearchControls allTags={allTags} total={total} />
        <Directory
            people={sorted}
            avatarSet={avatarSet}
            activity={(activity as ActivityData).people}
        />
    </main>

    <Footer />
</Base>
