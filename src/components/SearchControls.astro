---
import { tagLabel, tagSlug } from "../functions/tags";

interface Props {
	allTags: string[];
	total: number;
	shown: number;
	activeTag: string | null;
}

const { allTags, total, shown, activeTag } = Astro.props;

const SORTS = [
	{ key: "recent", label: "Recently active" },
	{ key: "az", label: "A–Z" },
];
---

<section
	class="sticky top-0 z-[5] mb-2 border-b border-border bg-bg/90 pt-4 pb-3 backdrop-blur-[8px] max-[520px]:static"
	aria-label="Filter and sort"
>
	<div>
		<div class="mb-[0.4rem] flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
			<span
				class="text-[0.78rem] font-semibold uppercase tracking-[0.06em] text-text-faint"
				id="tag-filter-label">Filter by tag</span
			>
			<p
				class="m-0 text-[0.85rem] text-text-dim [&_strong]:text-text"
				id="count"
				aria-live="polite"
			>
				Showing <strong>{shown}</strong> of <strong>{total}</strong> people
			</p>
		</div>
		<div
			class="flex flex-wrap gap-1.5"
			role="group"
			aria-labelledby="tag-filter-label"
		>
			{
				allTags.map((tag) => {
					const active = tag === activeTag;
					return (
						<a
							class="pill cursor-pointer rounded-full border border-border bg-bg-raised px-3 py-1 text-[0.8rem] font-semibold capitalize text-text-dim no-underline transition-colors duration-[120ms] hover:bg-bg-raised-hover hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue aria-pressed:border-green aria-pressed:bg-green aria-pressed:text-[#0c1418] motion-reduce:transition-none"
							href={active ? "/" : `/${tagSlug(tag)}/`}
							role="button"
							data-tag={tag}
							data-path={`/${tagSlug(tag)}/`}
							data-label={tagLabel(tag)}
							aria-pressed={active ? "true" : "false"}
						>
							{tag}
						</a>
					);
				})
			}
		</div>
	</div>

	<div class="mt-3">
		<span
			class="mb-[0.4rem] block text-[0.78rem] font-semibold uppercase tracking-[0.06em] text-text-faint"
			id="sort-label">Sort by</span
		>
		<div
			class="flex flex-wrap gap-1.5"
			role="group"
			aria-labelledby="sort-label"
		>
			{
				SORTS.map((s) => (
					<button
						type="button"
						class="sort-pill cursor-pointer rounded-full border border-border bg-bg-raised px-3 py-1 text-[0.8rem] font-semibold text-text-dim transition-colors duration-[120ms] hover:bg-bg-raised-hover hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue aria-pressed:border-blue aria-pressed:bg-blue aria-pressed:text-[#0c1418] motion-reduce:transition-none"
						data-sort={s.key}
						aria-pressed={s.key === "recent" ? "true" : "false"}
					>
						{s.label}
					</button>
				))
			}
		</div>
	</div>
</section>
