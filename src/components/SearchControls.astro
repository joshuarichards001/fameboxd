---
interface Props {
	allTags: string[];
	total: number;
}

const { allTags, total } = Astro.props;
---

<section
	class="sticky top-0 z-[5] mb-2 border-b border-border bg-bg/90 pt-4 pb-3 backdrop-blur-[8px] max-[520px]:static"
	aria-label="Search and filter"
>
	<div>
		<label
			class="mb-[0.4rem] block text-[0.78rem] font-semibold uppercase tracking-[0.06em] text-text-faint"
			for="search">Search by name, description, or tag</label
		>
		<input
			class="w-full rounded-card border border-border bg-bg-raised px-[0.9rem] py-[0.6rem] text-[1rem] text-text placeholder:text-text-faint focus-visible:border-transparent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue"
			type="search"
			id="search"
			name="search"
			placeholder="Search people, e.g. “director”, “Scorsese”, “youtuber”…"
			autocomplete="off"
			spellcheck="false"
		/>
	</div>

	<div class="mt-3">
		<div class="mb-[0.4rem] flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
			<span
				class="text-[0.78rem] font-semibold uppercase tracking-[0.06em] text-text-faint"
				id="tag-filter-label">Filter by tag</span
			>
			<p
				class="m-0 text-[0.85rem] text-text-dim [&_strong]:text-text"
				id="count"
				aria-live="polite"
			>
				Showing <strong>{total}</strong> of <strong>{total}</strong> people
			</p>
		</div>
		<div
			class="flex flex-wrap gap-1.5"
			role="group"
			aria-labelledby="tag-filter-label"
		>
			{
				allTags.map((tag) => (
					<button
						type="button"
						class="pill cursor-pointer rounded-full border border-border bg-bg-raised px-3 py-1 text-[0.8rem] font-semibold capitalize text-text-dim transition-colors duration-[120ms] hover:bg-bg-raised-hover hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue aria-pressed:border-green aria-pressed:bg-green aria-pressed:text-[#0c1418] motion-reduce:transition-none"
						data-tag={tag}
						aria-pressed="false"
					>
						{tag}
					</button>
				))
			}
		</div>
	</div>
</section>
