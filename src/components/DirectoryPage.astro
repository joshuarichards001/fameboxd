---
import people from "../data/people.json";
import { loadAvatarSet } from "../functions/avatars";
import { sortByRecentActivity, sortPeople, tagsByFrequency } from "../functions/people";
import { tagLabel } from "../functions/tags";
import { validatePeople } from "../functions/validate";
import Base from "../layouts/Base.astro";
import Directory from "./Directory.astro";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import SearchControls from "./SearchControls.astro";

interface Props {
	activeTag?: string | null;
}

const { activeTag = null } = Astro.props;

validatePeople(people);

const sorted = sortPeople(people);
const allTags = tagsByFrequency(sorted);
const total = sorted.length;
// Tag pages only render their own people; the client-side filter (homepage
// only) needs the full set.
const visible = activeTag
	? sorted.filter((p) => p.tags.includes(activeTag))
	: sorted;
const shown = visible.length;
const avatarSet = loadAvatarSet();

const label = activeTag ? tagLabel(activeTag) : null;
const title = label
	? `Famous ${label} on Letterboxd — Fameboxd`
	: "Famous People on Letterboxd — Actors, Directors & Creators | Fameboxd";
const description = label
	? `${shown} famous ${label.toLowerCase()} with verified public Letterboxd accounts — see what they're watching, how they rate films, and their all-time favorites.`
	: `A directory of ${total} famous actors, directors, musicians, youtubers, and creators with verified Letterboxd accounts.`;
---

<Base title={title} description={description}>
	<Header headline={label ?? "Famous"} />

	<main class="wrap">
		<SearchControls
			allTags={allTags}
			total={total}
			shown={shown}
			activeTag={activeTag}
		/>
		<Directory
			people={sortByRecentActivity(visible)}
			avatarSet={avatarSet}
			activeTag={activeTag}
		/>
	</main>

	<Footer />
</Base>
