---
import { SUGGEST_FORM_URL } from "../data/site";
---

<footer class="mt-10 border-t border-border pt-6 pb-8">
    <div class="wrap">
        <p class="m-0 mb-3 max-w-[60ch] text-[0.9rem] text-text-dim">
            Know someone missing? <a
                class="text-blue underline"
                href={SUGGEST_FORM_URL}
                target="_blank"
                rel="noopener">Suggest a person</a
            >.
        </p>
        <p class="m-0 max-w-[60ch] text-[0.9rem] text-text-faint">
            An unofficial fan directory. Not affiliated with, endorsed by, or
            connected to letterboxd.com. All profiles link out to their owners'
            public accounts, and profile pictures are each person's own public
            Letterboxd avatar.
        </p>
        <p class="m-0 mt-3 max-w-[60ch] text-[0.9rem] text-text-faint">
            Open source on <a
                class="text-blue underline"
                href="https://github.com/joshuarichards001/fameboxd"
                target="_blank"
                rel="noopener">GitHub</a
            >. Made by <a
                class="text-blue underline"
                href="https://josh.work"
                target="_blank"
                rel="noopener">Josh Richards</a
            >.
        </p>
    </div>
</footer>
