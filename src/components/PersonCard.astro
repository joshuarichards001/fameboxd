---
import { stars, timeAgo, type RecentFilm } from "../functions/activity";
import { hueFor, initials } from "../functions/avatars";
import type { Person } from "../functions/people";

interface Props {
	person: Person;
	hasAvatar: boolean;
	lastWatched: RecentFilm | null;
	hidden?: boolean;
}

const { person: p, hasAvatar, lastWatched, hidden = false } = Astro.props;
---

<li
	class="card flex [&[hidden]]:hidden"
	hidden={hidden}
	data-name={p.name.toLowerCase()}
	data-watched={lastWatched?.watchedDate ?? ""}
	data-tags={p.tags.join(" ")}
	data-haystack={`${p.name} ${p.description} ${p.tags.join(" ")}`.toLowerCase()}
>
	<a
		class="group flex w-full flex-col rounded-card border border-border bg-bg-raised px-4 pt-[0.9rem] pb-[0.85rem] no-underline transition-[border-color,transform,background] duration-[140ms] hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--color-orange)_45%,var(--color-border))] hover:bg-bg-raised-hover focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-blue motion-reduce:transition-none"
		href={`/${p.username}/`}
		aria-label={`View ${p.name}'s recent watches and favorite films`}
	>
		<div class="flex items-center gap-[0.7rem]">
			{
				hasAvatar ? (
					<img
						class="h-[42px] w-[42px] shrink-0 rounded-full border border-border bg-bg object-cover"
						src={`/avatars/${p.username}.webp`}
						width="42"
						height="42"
						loading="lazy"
						decoding="async"
						alt=""
					/>
				) : (
					<span
						class="flex h-[42px] w-[42px] shrink-0 items-center justify-center rounded-full border text-[0.9rem] font-bold tracking-[0.02em] text-[hsl(var(--hue)_55%_80%)] bg-[hsl(var(--hue)_32%_24%)] border-[hsl(var(--hue)_28%_34%)]"
						aria-hidden="true"
						style={`--hue:${hueFor(p.name)}`}
					>
						{initials(p.name)}
					</span>
				)
			}
			<h2 class="m-0 text-[1.05rem] font-bold leading-snug tracking-[-0.01em]">
				{p.name}
			</h2>
		</div>
		<ul class="mt-2 flex flex-wrap gap-[0.35rem]" aria-label="Tags">
			{
				p.tags.map((t) => (
					<li class="rounded-full border border-blue/30 bg-blue/[0.14] px-2 py-[0.1rem] text-[0.68rem] font-bold uppercase tracking-[0.04em] text-blue">
						{t}
					</li>
				))
			}
		</ul>
		<p class="mt-2 mb-3 flex-1 text-[0.875rem] leading-[1.5] text-text-dim">
			{p.description}
		</p>
		<span class="mt-auto flex flex-col gap-1 border-t border-border pt-2.5">
			{
				lastWatched && (
					<span class="flex items-baseline gap-x-1.5 text-[0.8rem] leading-snug">
							<span class="shrink-0 text-text-faint">Watched</span>
							<span class="min-w-0 truncate font-semibold text-text-dim">
								{lastWatched.title}
							</span>
							{lastWatched.rating != null && (
								<span
									class="shrink-0 text-green"
									aria-label={`rated ${lastWatched.rating} out of 5`}
								>
									{stars(lastWatched.rating)}
								</span>
							)}
							{lastWatched.watchedDate && (
								<span class="shrink-0 text-[0.75rem] text-text-faint">
									{timeAgo(lastWatched.watchedDate)}
								</span>
							)}
					</span>
				)
			}
			<span class="mt-1 flex items-baseline justify-between gap-2 text-[0.9rem] font-semibold">
				<span class="text-orange tabular-nums group-hover:underline">
					@{p.username}
				</span>
				<span
					class="text-[0.75rem] font-medium text-text-faint"
					aria-hidden="true"
				>
					more →
				</span>
			</span>
		</span>
	</a>
</li>
