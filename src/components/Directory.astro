---
import type { Person } from "../functions/people";
import PersonCard from "./PersonCard.astro";

interface Props {
	people: Person[];
	avatarSet: Set<string>;
	activeTag: string | null;
}

const { people, avatarSet, activeTag } = Astro.props;
---

<ul
	class="mt-4 grid grid-cols-[repeat(auto-fill,minmax(min(100%,21rem),1fr))] gap-3"
	id="directory"
	data-prefiltered={activeTag != null ? "" : undefined}
>
	{
		people.map((p) => (
			<PersonCard person={p} hasAvatar={avatarSet.has(p.username)} />
		))
	}
</ul>

<p class="my-12 text-center text-[1.15rem] text-text-dim" id="empty" hidden>
	No one found. Try a different tag.
</p>

<script is:inline>
	(function () {
		var directory = document.getElementById("directory");
		var cards = Array.prototype.slice.call(
			document.querySelectorAll(".card"),
		);
		var sortPills = Array.prototype.slice.call(
			document.querySelectorAll(".sort-pill"),
		);
		var sort = "recent";

		// Reorder the card <li>s in place. `cards` keeps the server's order,
		// which is already most-recently-active first.
		function applySort() {
			var order = cards.slice();
			if (sort === "az") {
				order.sort(function (a, b) {
					var an = a.getAttribute("data-name");
					var bn = b.getAttribute("data-name");
					return an < bn ? -1 : an > bn ? 1 : 0;
				});
			}
			for (var k = 0; k < order.length; k++) {
				directory.appendChild(order[k]);
			}
		}

		function syncSortPills() {
			sortPills.forEach(function (b) {
				b.setAttribute(
					"aria-pressed",
					b.getAttribute("data-sort") === sort ? "true" : "false",
				);
			});
		}

		sortPills.forEach(function (btn) {
			btn.addEventListener("click", function () {
				sort = btn.getAttribute("data-sort");
				syncSortPills();
				applySort();
			});
		});

		// Tag pages are pre-filtered on the server and only render their own
		// cards, so their pills stay plain links (real navigations). The
		// instant filter below needs every card in the DOM and only runs on
		// the full directory at "/".
		if (directory.hasAttribute("data-prefiltered")) return;

		var HOME_TITLE = document.title;
		var countEl = document.getElementById("count");
		var emptyEl = document.getElementById("empty");
		var headlineEl = document.getElementById("headline");
		var pills = Array.prototype.slice.call(
			document.querySelectorAll(".pill"),
		);
		var total = cards.length;
		var activeTag = null;

		function pillFor(tag) {
			for (var i = 0; i < pills.length; i++) {
				if (pills[i].getAttribute("data-tag") === tag) return pills[i];
			}
			return null;
		}

		function apply() {
			var shown = 0;
			for (var i = 0; i < cards.length; i++) {
				var card = cards[i];
				var show =
					!activeTag ||
					(" " + card.getAttribute("data-tags") + " ").indexOf(
						" " + activeTag + " ",
					) !== -1;
				card.hidden = !show;
				if (show) shown++;
			}
			countEl.innerHTML =
				"Showing <strong>" +
				shown +
				"</strong> of <strong>" +
				total +
				"</strong> people";
			emptyEl.hidden = shown !== 0;
		}

		function syncPills() {
			pills.forEach(function (p) {
				var on = p.getAttribute("data-tag") === activeTag;
				p.setAttribute("aria-pressed", on ? "true" : "false");
				p.setAttribute(
					"href",
					on ? "/" : p.getAttribute("data-path"),
				);
			});
		}

		// Keep the h1 and document title matching what the tag page would say.
		function syncHeadline() {
			var pill = activeTag ? pillFor(activeTag) : null;
			var label = pill ? pill.getAttribute("data-label") : null;
			if (headlineEl) headlineEl.textContent = label || "Famous";
			document.title = label
				? "Famous " + label + " on Letterboxd — Fameboxd"
				: HOME_TITLE;
		}

		// Mirror state into the URL so any view is shareable. The tag lives in
		// the path (a real prerendered page).
		function updateUrl() {
			var pill = activeTag ? pillFor(activeTag) : null;
			var path = pill ? pill.getAttribute("data-path") : "/";
			history.pushState(null, "", path);
		}

		// Derive all state from the current URL (initial load and popstate).
		function initFromUrl() {
			var path = location.pathname.replace(/\/*$/, "/");
			activeTag = null;
			pills.forEach(function (p) {
				if (p.getAttribute("data-path") === path) {
					activeTag = p.getAttribute("data-tag");
				}
			});
			syncPills();
			syncHeadline();
			apply();
		}

		pills.forEach(function (pill) {
			pill.addEventListener("click", function (e) {
				if (e.metaKey || e.ctrlKey || e.shiftKey) return;
				e.preventDefault();
				var tag = pill.getAttribute("data-tag");
				activeTag = activeTag === tag ? null : tag;
				syncPills();
				syncHeadline();
				apply();
				updateUrl();
			});
		});

		window.addEventListener("popstate", initFromUrl);
		initFromUrl();
	})();
</script>
