---
// One film tile: poster (or a text-only fallback) and an optional caption
// row (star rating / date) passed via the default slot. The title is only
// exposed as alt/tooltip text — the poster art carries it visually.

interface Props {
	title: string;
	poster: string | null;
	url: string | null;
}

const { title, poster, url } = Astro.props;
---

<li class="list-none">
	<a
		class="group block no-underline"
		href={url}
		target="_blank"
		rel="noopener"
		title={title}
		aria-label={title}
	>
		{
			poster ? (
				<img
					class="aspect-2/3 w-full rounded-[6px] border border-border bg-bg-raised object-cover transition-[border-color] duration-[120ms] group-hover:border-[color-mix(in_srgb,var(--color-orange)_55%,var(--color-border))]"
					src={poster}
					width="200"
					height="300"
					loading="lazy"
					decoding="async"
					alt={`Poster for ${title}`}
				/>
			) : (
				<span class="flex aspect-2/3 w-full items-center justify-center rounded-[6px] border border-border bg-bg-raised p-2 text-center text-[0.78rem] font-semibold leading-snug text-text-dim">
					{title}
				</span>
			)
		}
	</a>
	<slot />
</li>
